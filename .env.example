NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server/admin scripts only. Never expose this in browser code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required by /api/cron/scan-sources.
CRON_SECRET=replace-with-a-long-random-secret

# Optional: when present, seed script also creates user_sources for this user.
SIGNALDESK_BOOTSTRAP_USER_ID=00000000-0000-0000-0000-000000000000

# Optional for auth redirect links in local/dev deployments.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
